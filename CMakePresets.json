{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 18, "patch": 0 },
  "configurePresets": [
    {
      "name": "android-arm64",
      "displayName": "Android ARM64 (NDK)",
      "description": "Build for Android arm64-v8a using NDK toolchain",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/android-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26",
        "ANDROID_STL": "c++_shared",
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake"
        },
        "CMAKE_SHARED_LINKER_FLAGS": "-Wl,--gc-sections,--strip-all -s"
      }
    },
    {
      "name": "ci",
      "displayName": "CI Build (GitHub Actions)",
      "inherits": "android-arm64",
      "binaryDir": "build"
    }
  ],
  "buildPresets": [
    {
      "name": "android-arm64",
      "configurePreset": "android-arm64"
    },
    {
      "name": "ci",
      "configurePreset": "ci"
    }
  ]
}
